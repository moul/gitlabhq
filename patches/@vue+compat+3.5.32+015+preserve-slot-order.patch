diff --git a/node_modules/@vue/compat/dist/vue.cjs.js b/node_modules/@vue/compat/dist/vue.cjs.js
index aaaaaaa..bbbbbbb 100644
--- a/node_modules/@vue/compat/dist/vue.cjs.js
+++ b/node_modules/@vue/compat/dist/vue.cjs.js
@@ -6202,7 +6202,11 @@
   if (scopedSlots) {
     delete props.scopedSlots;
     if (slots) {
-      extend(slots, scopedSlots);
+      /*! patch-package: Preserve scopedSlots order by starting with it, then merging array children slots.
+       * This maintains template order where named slots typically appear before default content */
+      const arrayChildrenSlots = slots;
+      slots = extend({}, scopedSlots);
+      extend(slots, arrayChildrenSlots);
     } else {
       slots = scopedSlots;
     }
