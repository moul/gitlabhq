--- a/node_modules/@vue/compat/dist/vue.cjs.js
+++ b/node_modules/@vue/compat/dist/vue.cjs.js
@@ -12024,7 +12024,14 @@
       type = 32;
       const slotFlag = children._;
       if (!slotFlag && !isInternalObject(children)) {
-        children._ctx = currentRenderingInstance;
+        /*! patch-package: Preserve existing _ctx for slot context in async component scenarios
+         * When async components resolve and create inner component vnodes, normalizeChildren
+         * is called again. Without this check, _ctx would be overwritten with the async wrapper
+         * instance instead of the original parent where the slot content was defined.
+         * This ensures directives in slot content can be resolved from the defining component. */
+        if (!children._ctx) {
+          children._ctx = currentRenderingInstance;
+        }
       } else if (slotFlag === 3 && currentRenderingInstance) {
         if (currentRenderingInstance.slots._ === 1) {
           children._ = 1;
