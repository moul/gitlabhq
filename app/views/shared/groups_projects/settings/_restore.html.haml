- return unless context.self_deletion_scheduled?

= render Pajamas::CardComponent.new do |c|
  - c.with_header do
    %h4.gl-text-base.gl-leading-24.gl-m-0= restore_namespace_title(context)

  - c.with_body do
    %p= restore_namespace_scheduled_for_deletion_message(context)
    = gitlab_ui_form_for context, url: restore_namespace_path(context), method: :post do |f|
      = f.submit _('Restore'), pajamas_button: true, variant: :default, data: { event_tracking: tracking_event, event_label: 'setting' }
